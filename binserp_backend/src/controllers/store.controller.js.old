// ========== MASTERS (Vendor, Customer, Location) ==========




// Vendor
export const createVendor = async (req, res) => {
  try {
    const Vendor = req.getModel('Vendor', vendorSchema);

    const companyId = getCompanyId(req);
    let { name, code, bankDetails, ...otherData } = req.body;

    if (!name) {
      return res.status(400).json({ message: "Vendor name is required" });
    }

    // Auto-generate code if not provided
    if (!code) {
      const PrefixSettings = req.getModel("PrefixSettings", prefixSettingsSchema);
      const settings = await PrefixSettings.findOne() || new PrefixSettings();
      const prefix = settings.vendorPrefix || "VEN";
      
      const lastVendor = await Vendor.findOne({ company: companyId, code: { $regex: new RegExp(`^${prefix}`) } }).sort({ code: -1 });
      
      let nextNumber = 1;
      if (lastVendor && lastVendor.code) {
        const match = lastVendor.code.match(/\d+$/);
        if (match) {
          nextNumber = parseInt(match[0], 10) + 1;
        }
      }
      code = `${prefix}-${nextNumber.toString().padStart(3, '0')}`;
    }

    // Ensure robust bank details mapping
    const formattedBankDetails = bankDetails ? {
      accountNumber: bankDetails.accountNumber || "",
      ifscCode: bankDetails.ifscCode || "",
      bankName: bankDetails.bankName || "",
      branchName: bankDetails.branchName || bankDetails.branch || "", // Handle both keys
      accountName: bankDetails.accountName || "",
      swiftCode: bankDetails.swiftCode || "",
    } : {};

    const vendor = await Vendor.create({
      ...otherData,
      name,
      code,
      bankDetails: formattedBankDetails,
      company: companyId
    });

    res.status(201).json({ message: "Vendor created successfully", vendor });
  } catch (error) {
    console.error("Create Vendor Error:", error);
    if (error.code === 11000) {
      return res.status(400).json({ message: "Vendor code already exists" });
    }
    res.status(500).json({ message: error.message });
  }
};

