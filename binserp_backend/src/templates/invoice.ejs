<!DOCTYPE html>
<html>
<head>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap');
        body { font-family: 'Inter', sans-serif; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    </style>
</head>
<body class="bg-white p-8">
    <div class="max-w-4xl mx-auto">
        <!-- Header -->
        <div class="flex justify-between items-start mb-8">
            <div>
                <% if (companyInfo?.logo) { %>
                    <img src="<%= companyInfo.logo %>" class="h-16 mb-4" />
                <% } %>
                <h1 class="text-xl font-bold text-slate-800"><%= companyInfo?.companyName || 'Company Name' %></h1>
                <p class="text-sm text-slate-500 mt-1 max-w-xs"><%= companyInfo?.billingAddress || '' %></p>
                <% if (companyInfo?.contactNumber) { %><p class="text-sm text-slate-500">Phone: <%= companyInfo.contactNumber %></p><% } %>
                <% if (companyInfo?.email) { %><p class="text-sm text-slate-500">Email: <%= companyInfo.email %></p><% } %>
                <% if (companyInfo?.gstNumber) { %><p class="text-sm text-slate-500 mt-1 font-semibold">GSTIN: <%= companyInfo.gstNumber %></p><% } %>
            </div>
            <div class="text-right">
                <h2 class="text-3xl font-bold text-indigo-600 mb-2">TAX INVOICE</h2>
                <p class="text-sm text-slate-600"><span class="font-semibold">Invoice No:</span> <%= doc.invoiceNumber %></p>
                <p class="text-sm text-slate-600"><span class="font-semibold">Date:</span> <%= new Date(doc.date).toLocaleDateString() %></p>
            </div>
        </div>

        <!-- Bill To -->
        <div class="mb-8 p-4 bg-slate-50 rounded-lg border border-slate-100">
            <h3 class="text-sm font-bold text-slate-800 mb-2">BILL TO:</h3>
            <p class="text-sm font-semibold text-slate-700"><%= doc.customerName || doc.customer?.name || 'N/A' %></p>
            <p class="text-sm text-slate-500 mt-1"><%= doc.customerAddress || doc.customer?.address || '' %></p>
            <% if (doc.customerGST || doc.customer?.gstNumber) { %>
                <p class="text-sm text-slate-500 mt-1"><span class="font-semibold">GSTIN:</span> <%= doc.customerGST || doc.customer?.gstNumber %></p>
            <% } %>
        </div>

        <!-- Items Table -->
        <table class="w-full text-sm text-left mb-8">
            <thead class="text-xs text-white uppercase bg-indigo-600 rounded-t-lg">
                <tr>
                    <th class="px-4 py-3 rounded-tl-lg">Item</th>
                    <th class="px-4 py-3">HSN</th>
                    <th class="px-4 py-3 text-right">Qty</th>
                    <th class="px-4 py-3 text-right">Rate</th>
                    <th class="px-4 py-3 text-right">Tax %</th>
                    <th class="px-4 py-3 text-right rounded-tr-lg">Amount</th>
                </tr>
            </thead>
            <tbody>
                <% doc.items.forEach(function(item, index) { %>
                <tr class="border-b border-slate-200 <%= index % 2 === 0 ? 'bg-white' : 'bg-slate-50' %>">
                    <td class="px-4 py-3 font-medium text-slate-800"><%= item.materialName %></td>
                    <td class="px-4 py-3 text-slate-500"><%= item.hsnCode || '-' %></td>
                    <td class="px-4 py-3 text-right text-slate-600"><%= item.quantity %></td>
                    <td class="px-4 py-3 text-right text-slate-600"><%= Number(item.rate || 0).toFixed(2) %></td>
                    <td class="px-4 py-3 text-right text-slate-600"><%= item.taxRate || 0 %>%</td>
                    <td class="px-4 py-3 text-right font-medium text-slate-800"><%= (Number(item.amount || 0) + Number(item.taxAmount || 0)).toFixed(2) %></td>
                </tr>
                <% }); %>
            </tbody>
        </table>

        <!-- Totals -->
        <div class="flex justify-end mb-12">
            <div class="w-64">
                <div class="flex justify-between py-2 text-sm text-slate-600">
                    <span>Subtotal:</span>
                    <span><%= Number(doc.subtotal || 0).toFixed(2) %></span>
                </div>
                <div class="flex justify-between py-2 text-sm text-slate-600 border-b border-slate-200">
                    <span>Tax:</span>
                    <span><%= Number(doc.taxAmount || 0).toFixed(2) %></span>
                </div>
                <div class="flex justify-between py-3 text-base font-bold text-slate-800">
                    <span>Total:</span>
                    <span class="text-indigo-600"><%= Number(doc.totalAmount || 0).toFixed(2) %></span>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <div class="flex justify-between items-end mt-12 pt-8 border-t border-slate-200">
            <div class="w-2/3">
                <% if (companyInfo?.bankDetails) { %>
                    <h4 class="text-xs font-bold text-slate-800 mb-1">Bank Details:</h4>
                    <p class="text-xs text-slate-500">Bank: <%= companyInfo.bankDetails.bankName || '-' %></p>
                    <p class="text-xs text-slate-500">A/c No: <%= companyInfo.bankDetails.accountNumber || '-' %></p>
                    <p class="text-xs text-slate-500 mb-4">IFSC: <%= companyInfo.bankDetails.ifscCode || '-' %></p>
                <% } %>
                
                <% if (companyInfo?.commercialTerms) { %>
                    <h4 class="text-xs font-bold text-slate-800 mb-1">Terms & Conditions:</h4>
                    <p class="text-xs text-slate-500 max-w-md whitespace-pre-wrap"><%= companyInfo.commercialTerms %></p>
                <% } %>
            </div>
            
            <div class="text-right">
                <p class="text-sm font-bold text-slate-800 mb-8">Authorized Signatory</p>
                <p class="text-xs text-slate-500">For <%= companyInfo?.companyName || 'Company' %></p>
            </div>
        </div>
        
        <div class="mt-8 text-center text-[10px] text-slate-400">
            Generated on: <%= new Date().toLocaleString() %>
        </div>
    </div>
</body>
</html>
