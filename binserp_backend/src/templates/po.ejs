<!DOCTYPE html>
<html>
<head>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap');
        body { font-family: 'Inter', sans-serif; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    </style>
</head>
<body class="bg-white p-8">
    <div class="max-w-4xl mx-auto">
        <!-- Header -->
        <div class="flex justify-between items-start mb-8">
            <div>
                <% if (companyInfo?.logo) { %>
                    <img src="<%= companyInfo.logo %>" class="h-16 mb-4" />
                <% } %>
                <h1 class="text-xl font-bold text-slate-800"><%= companyInfo?.companyName || 'Company Name' %></h1>
                <p class="text-sm text-slate-500 mt-1 max-w-xs"><%= companyInfo?.billingAddress || '' %></p>
                <% if (companyInfo?.contactNumber) { %><p class="text-sm text-slate-500">Phone: <%= companyInfo.contactNumber %></p><% } %>
                <% if (companyInfo?.email) { %><p class="text-sm text-slate-500">Email: <%= companyInfo.email %></p><% } %>
            </div>
            <div class="text-right">
                <h2 class="text-3xl font-bold text-purple-600 mb-2">PURCHASE ORDER</h2>
                <p class="text-sm text-slate-600"><span class="font-semibold">PO No:</span> <%= doc.poNumber %></p>
                <p class="text-sm text-slate-600"><span class="font-semibold">Date:</span> <%= new Date(doc.date).toLocaleDateString() %></p>
                <p class="text-sm text-slate-600"><span class="font-semibold">Status:</span> <%= doc.status %></p>
            </div>
        </div>

        <!-- Vendor To -->
        <div class="mb-8 p-4 bg-slate-50 rounded-lg border border-slate-100">
            <h3 class="text-sm font-bold text-slate-800 mb-2">VENDOR:</h3>
            <p class="text-sm font-semibold text-slate-700"><%= doc.vendorName || doc.vendor?.name || 'N/A' %></p>
        </div>

        <!-- Items Table -->
        <table class="w-full text-sm text-left mb-8">
            <thead class="text-xs text-white uppercase bg-purple-600 rounded-t-lg">
                <tr>
                    <th class="px-4 py-3 rounded-tl-lg">Material</th>
                    <th class="px-4 py-3 text-right">Qty</th>
                    <th class="px-4 py-3">Unit</th>
                    <th class="px-4 py-3 text-right">Rate</th>
                    <th class="px-4 py-3 text-right rounded-tr-lg">Amount</th>
                </tr>
            </thead>
            <tbody>
                <% 
                const items = doc.items && doc.items.length > 0 ? doc.items : [{
                    materialName: doc.materialName,
                    quantity: doc.quantity,
                    unit: doc.unit,
                    rate: doc.rate,
                    amount: doc.amount
                }];
                items.forEach(function(item, index) { 
                %>
                <tr class="border-b border-slate-200 <%= index % 2 === 0 ? 'bg-white' : 'bg-slate-50' %>">
                    <td class="px-4 py-3 font-medium text-slate-800"><%= item.materialName || 'N/A' %></td>
                    <td class="px-4 py-3 text-right text-slate-600"><%= item.quantity || 0 %></td>
                    <td class="px-4 py-3 text-slate-600"><%= item.unit || 'PCS' %></td>
                    <td class="px-4 py-3 text-right text-slate-600"><%= Number(item.rate || 0).toFixed(2) %></td>
                    <td class="px-4 py-3 text-right font-medium text-slate-800"><%= Number(item.amount || 0).toFixed(2) %></td>
                </tr>
                <% }); %>
            </tbody>
        </table>

        <!-- Totals -->
        <div class="flex justify-end mb-12">
            <div class="w-64">
                <div class="flex justify-between py-3 text-base font-bold text-slate-800">
                    <span>Total Amount:</span>
                    <span class="text-purple-600"><%= Number(doc.totalAmount || doc.amount || 0).toFixed(2) %></span>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <div class="flex justify-between items-end mt-12 pt-8 border-t border-slate-200">
            <div class="w-2/3">
                <% if (companyInfo?.commercialTerms) { %>
                    <h4 class="text-xs font-bold text-slate-800 mb-1">Terms & Conditions:</h4>
                    <p class="text-xs text-slate-500 max-w-md whitespace-pre-wrap"><%= companyInfo.commercialTerms %></p>
                <% } %>
            </div>
            
            <div class="text-right">
                <p class="text-sm font-bold text-slate-800 mb-8">Authorized Signatory</p>
                <p class="text-xs text-slate-500">For <%= companyInfo?.companyName || 'Company' %></p>
            </div>
        </div>
        
        <div class="mt-8 text-center text-[10px] text-slate-400">
            Generated on: <%= new Date().toLocaleString() %>
        </div>
    </div>
</body>
</html>
